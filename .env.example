# =============================================
# LINE Messaging API
# =============================================
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
# 推播目標（逗號分隔，支援多個）：C 開頭=群組、U 開頭=個人、R 開頭=聊天室
LINE_TARGETS=C1234567890abcdef1234567890abcdef,Uabcdef1234567890abcdef1234567890

# =============================================
# 計費設定
# =============================================
FREE_QUOTA=1000
PRICING_MODEL=single
# PRICING_MODEL=tiers

# 方案月費（元）：固定費用，不論用量每月皆計收；設為 0 表示不計入
PLAN_FEE=0

# single 模式：每則單價（元）
SINGLE_UNIT_PRICE=0.2

# tiers 模式：級距 JSON（upTo=null 表示無上限最後一級）
# TIERS_JSON=[{"upTo":10000,"price":0.2},{"upTo":50000,"price":0.18},{"upTo":null,"price":0.16}]

# =============================================
# AWS 設定
# =============================================
AWS_REGION=ap-northeast-1

# DynamoDB 資料表名稱
DDB_TABLE_SNAPSHOTS=usage_snapshots
DDB_TABLE_RUNS=job_runs

# 本機測試用：DynamoDB Local endpoint（部署時不需設定）
# AWS_ENDPOINT_URL=http://localhost:8000

# =============================================
# 其他設定
# =============================================
CURRENCY=TWD
LOG_LEVEL=info
TZ=Asia/Taipei

# dry-run 模式：跳過 LINE 實際推播（僅印出訊息）
# DRY_RUN=true
